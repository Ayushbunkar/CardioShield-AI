# CardioShield AI - Client Environment Configuration
# Copy this file to .env and fill in your values
#
# DEPLOYMENT NOTE:
# On Render Static Site, set these as environment variables.
# The Vite dev proxy (/api) does NOT exist in production builds.
# You MUST set VITE_AI_API_URL and VITE_SERVER_URL to deployed URLs.

# ==============================================
# API ENDPOINTS (REQUIRED for production)
# ==============================================
# Express backend URL (auth, users, assessments, admin)
# Dev: http://localhost:4500
# Prod: https://cardioshield-server.onrender.com
VITE_SERVER_URL=http://localhost:4500

# AI Flask backend URL
# Dev: leave empty (Vite proxy handles /api → localhost:5001)
# Prod: https://cardioshield-ai.onrender.com
# VITE_AI_API_URL=

# ==============================================
# FEATURE FLAGS
# ==============================================
# Enable/disable location features
VITE_ENABLE_LOCATION_FEATURES=true

# ==============================================
# MAP CONFIGURATION
# ==============================================
# Default search radius in meters
VITE_DEFAULT_SEARCH_RADIUS=10000

# Maximum places to fetch
VITE_MAX_PLACES_LIMIT=20
