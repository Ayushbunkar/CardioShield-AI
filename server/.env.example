# CardioShield Server — Environment Variables
# =============================================

# Port (Render sets this automatically)
PORT=4500

# Environment
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/cardioshield

# JWT secret for authentication
JWT_SECRET=your-jwt-secret-change-this

# AI Flask backend URL
# In production: set to your deployed Render Flask service URL
AI_BACKEND_URL=http://localhost:5001

# CORS allowed origins (comma-separated)
# In production: set to your deployed React frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudinary (optional — for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional — for notifications)
EMAIL_USER=
EMAIL_PASS=
